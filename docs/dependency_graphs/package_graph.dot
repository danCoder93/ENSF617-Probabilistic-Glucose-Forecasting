digraph dependencies {
  label="Package Dependency Graph";
  labelloc=t;
  fontname="Helvetica";
  rankdir=LR;
  node [fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=9, color="#7d8597"];
  "config" [label="config", shape="folder", style="filled", fillcolor="#d9eaf4", color="#0b3954"];
  "data" [label="data", shape="folder", style="filled", fillcolor="#d9eaf4", color="#0b3954"];
  "defaults" [label="defaults", shape="box", style="filled,rounded", fillcolor="#f4d35e", color="#7f6000"];
  "environment" [label="environment", shape="folder", style="filled", fillcolor="#d9eaf4", color="#0b3954"];
  "evaluation" [label="evaluation", shape="folder", style="filled", fillcolor="#d9eaf4", color="#0b3954"];
  "main" [label="main", shape="box", style="filled,rounded", fillcolor="#f4d35e", color="#7f6000"];
  "models" [label="models", shape="folder", style="filled", fillcolor="#d9eaf4", color="#0b3954"];
  "observability" [label="observability", shape="folder", style="filled", fillcolor="#d9eaf4", color="#0b3954"];
  "train" [label="train", shape="folder", style="filled", fillcolor="#d9eaf4", color="#0b3954"];
  "utils" [label="utils", shape="folder", style="filled", fillcolor="#d9eaf4", color="#0b3954"];
  "workflows" [label="workflows", shape="folder", style="filled", fillcolor="#d9eaf4", color="#0b3954"];
  "config" -> "utils" [color="#7d8597", style="solid"];
  "data" -> "config" [color="#7d8597", style="solid"];
  "data" -> "utils" [color="#7d8597", style="solid"];
  "defaults" -> "config" [color="#7d8597", style="solid"];
  "environment" -> "config" [color="#7d8597", style="solid"];
  "main" -> "defaults" [color="#7d8597", style="solid"];
  "main" -> "workflows" [color="#7d8597", style="solid"];
  "models" -> "config" [color="#7d8597", style="solid"];
  "models" -> "evaluation" [color="#7d8597", style="solid"];
  "observability" -> "config" [color="#7d8597", style="solid"];
  "observability" -> "evaluation" [color="#7d8597", style="solid"];
  "train" -> "config" [color="#7d8597", style="solid"];
  "train" -> "data" [color="#7d8597", style="solid"];
  "train" -> "environment" [color="#7d8597", style="solid"];
  "train" -> "models" [color="#7d8597", style="solid"];
  "train" -> "observability" [color="#7d8597", style="solid"];
  "workflows" -> "config" [color="#7d8597", style="solid"];
  "workflows" -> "data" [color="#7d8597", style="solid"];
  "workflows" -> "defaults" [color="#7d8597", style="solid"];
  "workflows" -> "environment" [color="#7d8597", style="solid"];
  "workflows" -> "evaluation" [color="#7d8597", style="solid"];
  "workflows" -> "observability" [color="#7d8597", style="solid"];
  "workflows" -> "train" [color="#7d8597", style="solid"];
}
